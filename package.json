{
  "name": "trinity-extension",
  "displayName": "Trinity",
  "description": "Registra tus horas de trabajo en Trinity de forma rápida: plantillas reutilizables, cronómetro de actividad y cierre de día en un clic.",
  "private": true,
  "version": "0.1.0",
  "author": "Guillermo Paredes (codevs) <gdavid.ptorrez@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "vite --mode chrome",
    "dev:firefox": "vite build --mode firefox --watch",
    "build": "tsc && vite build --mode chrome",
    "build:firefox": "tsc && vite build --mode firefox",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:spell": "cspell --no-progress --cache \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "preview": "vite preview",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@crxjs/vite-plugin": "^2.0.3",
    "@ianvs/prettier-plugin-sort-imports": "^4.2.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@thedutchcoder/postcss-rem-to-px": "^0.0.2",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.12.2",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/webextension-polyfill": "^0.12.4",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.5.1",
    "autoprefixer": "^10.4.19",
    "cspell": "^9.2.2",
    "daisyui": "^5.0.46",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "postcss": "^8.5.6",
    "postcss-prefix-selector": "^1.16.0",
    "prettier": "^3.2.5",
    "prettier-plugin-css-order": "^2.1.2",
    "prettier-plugin-tailwindcss": "^0.5.13",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^6.4.1"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.x",
    "pnpm": ">=8.15.0"
  }
}
